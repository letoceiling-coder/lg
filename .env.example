# === Database ===
DATABASE_URL=postgresql://lg_admin:PASSWORD@localhost:5432/lg_production

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# === API ===
API_PORT=3000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
PUBLIC_SITE_URL=https://livegrid.ru

# === Meilisearch (опционально; без MEILI_HOST поиск каталога — только PostgreSQL) ===
# Локально: docker compose --profile search up -d  →  http://localhost:7700
# MEILI_HOST=http://localhost:7700
# MEILI_API_KEY=
# После первого включения: POST /api/v1/admin/search/reindex-catalog (роль admin)

# === PostGIS (миграция создаёт расширение и gist-индекс по координатам ЖК) ===
# На managed-БД без прав на CREATE EXTENSION примените postgis вручную и повторите миграцию при необходимости.

# === Sentry (опционально) ===
# API: DSN проекта Node/Nest (или общий SENTRY_DSN)
SENTRY_DSN_API=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# Доля транзакций performance (0–1), по умолчанию 0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_DEBUG=1

# Витрина: DSN браузерного проекта (Vite — только префикс VITE_)
# VITE_SENTRY_DSN_WEB=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_ENVIRONMENT=production

# Prometheus: если задан, scrape только с заголовком Authorization: Bearer <token>
# METRICS_BEARER_TOKEN=
# Grafana admin credentials (docker compose monitoring profile)
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=change-me
# Базовый URL для каноникала и SEO (витрина). Можно не задавать — подставится из PUBLIC_SITE_URL при сборке.
# VITE_PUBLIC_SITE_URL=https://livegrid.ru

# === TrendAgent ===
TRENDAGENT_BASE_URL=https://dataout.trendagent.ru
TRENDAGENT_DEFAULT_REGION=msk
# CSV-список регионов для cron-импорта (например: msk,spb,krd). Можно указать all для всех enabled feed_regions.
TRENDAGENT_REGIONS=msk
# Локальные фиды (вместо скачивания по URL): абсолютный путь к каталогу data, напр. C:\OSPanel\domains\lg\TrendAgent\data
FEED_LOCAL_DIR=
# BullMQ: вторник 03:00 UTC = 06:00 MSK (зимнее). Отключить: FEED_IMPORT_DISABLE_REPEAT=true
FEED_IMPORT_CRON=0 3 * * 2
FEED_IMPORT_DISABLE_REPEAT=

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lg-media
S3_REGION=us-east-1

# === Telegram ===
# Токен бота/username настраиваются в админке: Настройки сайта → группа «Интеграции (Telegram)»
# Публичный webhook URL для команд бота (/start, /admin, ...), endpoint: POST /api/v1/telegram-bot/webhook
TELEGRAM_WEBHOOK_URL=${PUBLIC_SITE_URL}/api/v1/telegram-bot/webhook
# MTProto parser для импорта новостей из Telegram-каналов (admin/news/sync-telegram)
# Получить в https://my.telegram.org (API development tools)
TG_API_ID=
TG_API_HASH=
# Авторизованная string session MTProto (не коммитить в git)
TG_SESSION_STRING=
# Каналы через запятую, например: @channel_one,@channel_two
TG_NEWS_CHANNELS=

# === Yandex Maps (опционально; предпочтительно ключ в админке → site_settings → yandex_maps_api_key, GET /content/maps-config) ===
YANDEX_MAPS_API_KEY=
